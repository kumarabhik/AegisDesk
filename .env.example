# Hackathon-preferred inference path through the Hugging Face router.
HF_TOKEN=your_hugging_face_token_here
API_BASE_URL=https://router.huggingface.co/v1
MODEL_NAME=Qwen/Qwen2.5-7B-Instruct-1M

# Point to a local server while developing, or to the live Space for remote checks.
ENV_BASE_URL=http://127.0.0.1:7860

# Optional compatibility fallback for non-HF OpenAI-compatible providers.
OPENAI_API_KEY=
